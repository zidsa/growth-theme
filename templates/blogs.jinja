  {'id': 6, 'slug': 'blog-title-heading-6', 'title': 'Blog Title Heading Will Go Here', 'description': 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros.', 'image': mock_image, 'category': 'CATEGORY', 'tags': mock_tags, 'date': '11 Jan 2025'},
] %}

{# Use real data when available, fall back to mock #}
{% set blog_categories = categories | default(mock_categories) %}
{% set blog_list = blogs | default(mock_blogs) %}
{% set active_category = session.query_params.get('category', '') if session is defined else '' %}

{# Pagination setup #}
{% set page_size = (session.query_params.get('page_size') or '12') | int if session is defined else 12 %}
{% set totalPages = 15 %}
{% set currentPage = (session.query_params.get('page') or '1') | int if session is defined else 1 %}

{% block title %}{{ store.name }} – {{ _('Blog') }}{% endblock %}

{% block content %}
  <style>
    /* Grid */
    .blog-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2.5rem 1.5rem;
    }
    @media (min-width: 768px) {
      .blog-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (min-width: 1024px) {
      .blog-grid { grid-template-columns: repeat(3, 1fr); }
    }

    /* Card */
    .blog-card {
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* Image */
    .blog-card-image {
      position: relative;
      display: block;
      width: 100%;
      aspect-ratio: 4 / 3;
      overflow: hidden;
      border-radius: var(--radius, 0.25rem) var(--radius, 0.25rem) 0 0;
    }
    .blog-card-image img,
    .blog-card-image .blog-card-placeholder {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .blog-card-placeholder {
      display: flex;
      align-items: center;
      justify-content: center;
      background: #F6F5F4;
    }

    /* Content area */
    .blog-card-content {
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding: 20px 24px 24px;
      background: #F6F5F4;
      flex: 1;
      border-radius: 0 0 var(--radius, 0.25rem) var(--radius, 0.25rem);
    }

    /* Title - 24px bold uppercase */
    .blog-card-title {
      font-size: 24px;
      font-weight: 700;
      line-height: 1.3;
      text-transform: uppercase;
      color: var(--foreground, #0B0A09);
      margin: 0;
    }
    .blog-card-title a {
      color: inherit;
      text-decoration: none;
    }

    /* Description - Body 2, primary color */
    .blog-card-description {
      font-size: 14px;
      font-weight: 400;
      line-height: 1.5;
      color: var(--foreground, #0B0A09);
      margin: 0;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    /* Tags */
    .blog-card-tags {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 8px;
    }
    .blog-tag {
      display: inline-flex;
      align-items: center;
      border: 1px solid var(--foreground, #0B0A09);
      border-radius: 9999px;
      padding: 4px 12px;
      font-size: 12px;
      line-height: 1.5;
      color: var(--foreground, #0B0A09);
    }
    .blog-tag--category {
      font-weight: 500;
    }
    .blog-tag--more {
      border-color: var(--border, #B5B5B5);
      color: var(--muted, #545352);
    }

    /* Footer */
    .blog-card-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: auto;
      padding-top: 8px;
    }
    .blog-card-date {
      font-size: 14px;
      color: var(--foreground, #0B0A09);
    }
    .blog-card-readmore {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 14px;
      font-weight: 500;
      color: var(--foreground, #0B0A09);
      text-decoration: none;
      margin-inline-start: auto;
    }
  </style>

  {# Breadcrumb Section #}
  <section class="px-4 py-6 md:px-16">
    <div class="theme-container">
      {%
        with
        items=[
          {'href': url_for('home'), 'label': _("Home")},
          {'label': _("Blog")}
        ]
      %}
        {% include 'components/ui/breadcrumb.jinja' %}
      {% endwith %}
    </div>
  </section>

  {# Blog Content #}
  <section class="px-4 pb-6 md:px-16 md:pb-16">
    <div class="theme-container">
      <div class="flex flex-col gap-8">
        {# Page Title #}
        <h1 class="text-foreground text-2xl font-bold uppercase tracking-tight md:text-3xl">
          {{ _("Blog") }}
        </h1>

        {# Category Filter Pills #}
        <div class="flex flex-wrap items-center gap-3">
          <a
            href="/blogs"
            class="{{ 'bg-foreground text-background' if not active_category else 'border-border text-foreground border' }} rounded-full px-5 py-2 text-sm font-medium transition-colors"
          >
            {{ _("All categories") }}
          </a>
          {% for category in blog_categories %}
            <a
              href="/blogs?category={{ category.slug }}"
              class="{{ 'bg-foreground text-background' if active_category == category.slug else 'border-border text-foreground border' }} rounded-full px-5 py-2 text-sm font-medium transition-colors"
            >
              {{ category.name }}
            </a>
          {% endfor %}
        </div>

        {# Blog Cards Grid #}
        {% if blog_list | length > 0 %}
          <div class="blog-grid">
            {% for blog in blog_list %}
              {% include 'components/blogs/blog-card.jinja' %}
            {% endfor %}
          </div>
        {% else %}
          {# Empty State #}
          <div class="flex flex-col items-center justify-center py-16 text-center">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="64"
              height="64"
              viewBox="0 0 24 24"
              fill="none"
              class="text-muted-foreground mb-6"
            >
              <path
                d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"
                stroke="currentColor"
                stroke-width="1"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
              <polyline
                points="14 2 14 8 20 8"
                stroke="currentColor"
                stroke-width="1"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
              <line
                x1="16" y1="13" x2="8" y2="13"
                stroke="currentColor"
                stroke-width="1"
                stroke-linecap="round"
              />
              <line
                x1="16" y1="17" x2="8" y2="17"
                stroke="currentColor"
                stroke-width="1"
                stroke-linecap="round"
              />
            </svg>
            <h3 class="text-foreground text-h6 mb-2">{{ _("No posts found") }}</h3>
            <p class="text-muted-foreground text-body2">
              {{ _("No posts found, please visit this page later") }}
            </p>
          </div>
        {% endif %}

        {# Pagination #}
        {% include 'components/blogs/blog-pagination.jinja' %}
      </div>
    </div>
  </section>
{% endblock %}

