{% set mock_blogs = [
  {'id': 1, 'slug': 'blog-title-heading-1', 'title': 'Blog Title Heading Will Go Here', 'description': 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros. Lorem ipsum dolor sit amet, consectetur adipiscing elit.', 'image': mock_image, 'category': 'CATEGORY', 'tags': mock_tags, 'date': '11 Jan 2025'},
  {'id': 2, 'slug': 'blog-title-heading-2', 'title': 'Blog Title Heading Will Go Here', 'description': 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros.', 'image': mock_image, 'category': 'CATEGORY', 'tags': mock_tags, 'date': '11 Jan 2025'},
  {'id': 3, 'slug': 'blog-title-heading-3', 'title': 'Blog Title Heading Will Go Here', 'description': 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros.', 'image': mock_image, 'category': 'CATEGORY', 'tags': mock_tags, 'date': '11 Jan 2025'},
  {'id': 4, 'slug': 'blog-title-heading-4', 'title': 'Blog Title Heading Will Go Here', 'description': 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros. Lorem ipsum dolor sit amet, consectetur adipiscing elit.', 'image': none, 'category': 'CATEGORY', 'tags': mock_tags, 'date': '11 Jan 2025'},
