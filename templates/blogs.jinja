{% extends "layout.jinja" %}

{# Data binding — backend provides posts (PaginatedBlogPosts) and categories (PaginatedBlogCategories) #}
{% set blog_list = posts.results if posts is defined and posts.results else [] %}
{% set blog_categories = categories.results if categories is defined and categories.results else [] %}
{% set active_category_slug = session.query_params.get('category', '') if session is defined else '' %}

{# When no category param is set, the backend defaults to the first category #}
{% set effective_category_slug = active_category_slug or (blog_categories[0].slug if blog_categories | length > 0 else '') %}
{% set ns = namespace(active_category_obj=none) %}
{% for category in blog_categories %}
  {% if category.slug == effective_category_slug %}
    {% set ns.active_category_obj = category %}
  {% endif %}
{% endfor %}
{% set active_category_obj = ns.active_category_obj %}

{# Pagination #}
{% set page_size = posts.page_size | default(12) if posts is defined else 12 %}
{% set totalPages = ((posts.count / page_size) | round(0, 'ceil')) | int if posts is defined and posts.count else 1 %}
{% set currentPage = posts.page | default(1) if posts is defined else 1 %}

{% block title %}{{ store.name }} – {{ _('Blog') }}{% endblock %}

{% block content %}
  {# Breadcrumb Section #}
  <section class="px-4 py-6 md:px-16">
    <div class="theme-container">
      {% set breadcrumb_items = [{'href': url_for('home'), 'label': _("Home")}] %}
      {% if active_category_obj %}
        {% set breadcrumb_items = breadcrumb_items + [{'href': '/blogs', 'label': _("Blog")}, {'label': active_category_obj.name}] %}
      {% else %}
        {% set breadcrumb_items = breadcrumb_items + [{'label': _("Blog")}] %}
      {% endif %}
      {% with items=breadcrumb_items %}
        {% include 'components/ui/breadcrumb.jinja' %}
      {% endwith %}
    </div>
  </section>

  {# Blog Content #}
  <section class="px-4 pb-6 md:px-16 md:pb-16">
    <div class="theme-container">
      <div class="flex flex-col gap-8">
        {# Page Title #}
        <h1 class="text-foreground text-3xl font-bold uppercase md:text-4xl">
          {{ _("Blog") }}
        </h1>

        {# Category Filter Pills #}
        {% if blog_categories | length > 0 %}
          <div class="flex flex-nowrap items-center gap-3 overflow-x-auto pb-2">
            {% for category in blog_categories %}
              <a
                href="/blogs?category={{ category.slug }}"
                class="inline-flex items-center justify-center whitespace-nowrap rounded-lg border px-5 py-2.5 text-sm font-medium transition-colors {{ 'bg-foreground text-background border-foreground' if effective_category_slug == category.slug else 'border-foreground text-foreground' }}"
              >
                {{ category.name }}
              </a>
            {% endfor %}
          </div>
        {% endif %}

        {# Blog Cards Grid #}
        {% if blog_list | length > 0 %}
          <div class="grid grid-cols-1 gap-x-6 gap-y-10 md:grid-cols-2 lg:grid-cols-3">
            {% for blog in blog_list %}
              {% include 'components/blogs/blog-card.jinja' %}
            {% endfor %}
          </div>
        {% else %}
          {# Empty State #}
          <div class="flex flex-col items-center justify-center py-16 text-center">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="64"
              height="64"
              viewBox="0 0 24 24"
              fill="none"
              class="text-muted-foreground mb-6"
            >
              <path
                d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"
                stroke="currentColor"
                stroke-width="1"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
              <polyline
                points="14 2 14 8 20 8"
                stroke="currentColor"
                stroke-width="1"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
              <line
                x1="16" y1="13" x2="8" y2="13"
                stroke="currentColor"
                stroke-width="1"
                stroke-linecap="round"
              />
              <line
                x1="16" y1="17" x2="8" y2="17"
                stroke="currentColor"
                stroke-width="1"
                stroke-linecap="round"
              />
            </svg>
            <h3 class="text-foreground text-h6 mb-2">{{ _("No posts found") }}</h3>
            <p class="text-muted-foreground text-body2">
              {{ _("No posts found, please visit this page later") }}
            </p>
          </div>
        {% endif %}

        {# Pagination #}
        {% include 'components/blogs/blog-pagination.jinja' %}
      </div>
    </div>
  </section>

  {% include 'components/blogs/blog-scripts.jinja' %}
{% endblock %}
