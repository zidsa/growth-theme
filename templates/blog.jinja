{% extends "layout.jinja" %}

{% set blog = post if post is defined else blog %}
{% set cover_image = blog.cover.image.large if blog.cover and blog.cover.image else none %}
{% set blog_category = blog.category if blog.category else none %}
{% set all_tags = blog.tags | default([]) %}
{% set featured_products = blog.related_products | default([]) %}
{% set related_posts = blog.related_posts | default([]) %}

{% block title %}{{ blog.title }} – {{ store.name }}{% endblock %}

{% block content %}
  {# Breadcrumb Section #}
  <section class="px-4 py-6 md:px-16">
    <div class="theme-container">
      {%
        with
        items=[
          {'href': url_for('home'), 'label': _("Home")},
          {'href': '/blogs', 'label': _("Blog")},
          {'label': blog.title}
        ]
      %}
        {% include 'components/ui/breadcrumb.jinja' %}
      {% endwith %}
    </div>
  </section>

  {# Blog Post Content #}
  <section class="px-4 pb-8 md:px-16 md:pb-16">
    <div class="theme-container">
      <article class="mx-auto max-w-[900px]">
        {# Cover Image #}
        {% if cover_image %}
          <div class="mb-8 w-full overflow-hidden rounded aspect-[21/9]">
            <img
              src="{{ cover_image }}"
              alt="{{ blog.title }}"
              class="h-full w-full object-cover"
              fetchpriority="high"
            />
          </div>
        {% endif %}

        {# Title #}
        <h1 class="text-foreground text-2xl font-bold uppercase leading-tight md:text-[32px]">
          {{ blog.title }}
        </h1>

        {# Date + Share Icons row #}
        <div class="mt-3 mb-6 flex items-center justify-between">
          {% if blog.published_at %}
            <span class="text-foreground text-sm" dir="ltr" data-blog-date="{{ blog.published_at }}">
              {{ blog.published_at }}
            </span>
          {% else %}
            <span></span>
          {% endif %}
          <div class="flex shrink-0 items-center gap-4">
            {# Copy link #}
            <a
              href="javascript:void(0)"
              data-copy-link
              class="text-foreground flex"
              title="{{ _('Copy link') }}"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            </a>
            {# Twitter/X #}
            <a
              href="https://twitter.com/intent/tweet?text={{ blog.title | urlencode }}&url={{ store.permalink }}blogs/{{ blog.slug }}"
              target="_blank"
              rel="noopener"
              class="text-foreground flex"
              title="{{ _('Share on X') }}"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            {# WhatsApp #}
            <a
              href="https://api.whatsapp.com/send?text={{ blog.title | urlencode }}%20{{ store.permalink }}blogs/{{ blog.slug }}"
              target="_blank"
              rel="noopener"
              class="text-foreground flex"
              title="{{ _('Share on WhatsApp') }}"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </a>
            {# Facebook #}
            <a
              href="https://www.facebook.com/sharer/sharer.php?u={{ store.permalink }}blogs/{{ blog.slug }}"
              target="_blank"
              rel="noopener"
              class="text-foreground flex"
              title="{{ _('Share on Facebook') }}"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          </div>
        </div>

        {# Rich Text Content #}
        <div class="prose prose-theme max-w-none">
          {{ blog.content | safe }}
        </div>

        {# Tags + Share Icons #}
        <div class="mt-6 flex items-center justify-between gap-4">
          <div class="flex flex-wrap items-center gap-3">
            {% if blog_category %}
              <span class="bg-secondary text-foreground inline-flex items-center rounded px-3 py-1 text-xs font-medium">
                {{ blog_category.name }}
              </span>
            {% endif %}
            {% for tag in all_tags %}
              <span class="bg-secondary text-foreground inline-flex items-center rounded px-3 py-1 text-xs">
                {{ tag.name }}
              </span>
            {% endfor %}
          </div>
          <div class="flex shrink-0 items-center gap-4">
            <a href="javascript:void(0)" data-copy-link-bottom class="text-foreground flex" title="{{ _('Copy link') }}">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            </a>
            <a href="https://twitter.com/intent/tweet?text={{ blog.title | urlencode }}&url={{ store.permalink }}blogs/{{ blog.slug }}" target="_blank" rel="noopener" class="text-foreground flex" title="{{ _('Share on X') }}">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <a href="https://api.whatsapp.com/send?text={{ blog.title | urlencode }}%20{{ store.permalink }}blogs/{{ blog.slug }}" target="_blank" rel="noopener" class="text-foreground flex" title="{{ _('Share on WhatsApp') }}">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </a>
            <a href="https://www.facebook.com/sharer/sharer.php?u={{ store.permalink }}blogs/{{ blog.slug }}" target="_blank" rel="noopener" class="text-foreground flex" title="{{ _('Share on Facebook') }}">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          </div>
        </div>
      </article>
    </div>
  </section>

  {# Featured Products #}
  {% if featured_products | length > 0 %}
    <section class="px-4 py-6 md:px-16 md:py-8">
      <div class="theme-container">
        {%
          with
          products=featured_products,
          title=_("Featured Products"),
          more_url=url_for('list_products'),
          more_text=_("View all"),
          carousel_id='blog-featured-products',
          is_priority_section=false
        %}
          {% include 'components/products/products-carousel.jinja' %}
        {% endwith %}
      </div>
    </section>
  {% endif %}

  {# You May Also Like — Related Posts #}
  {% if related_posts | length > 0 %}
    <section class="px-4 py-6 md:px-16 md:py-8">
      <div class="theme-container">
        {%
          with
          posts=related_posts,
          title=_("You may also like"),
          more_url='/blogs',
          more_text=_("View all"),
          carousel_id='blog-related-posts'
        %}
          {% include 'components/blogs/blogs-carousel.jinja' %}
        {% endwith %}
      </div>
    </section>
  {% endif %}

  {# Scripts: date formatter + copy link #}
  <script>
    (function () {
      // Format dates
      var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      document.querySelectorAll('[data-blog-date]').forEach(function (el) {
        try {
          var d = new Date(el.getAttribute('data-blog-date'));
          if (!isNaN(d)) {
            el.textContent = d.getDate() + ' ' + months[d.getMonth()] + ' ' + d.getFullYear();
          }
        } catch (e) {}
      });

      // Copy link buttons
      document.querySelectorAll('[data-copy-link], [data-copy-link-bottom]').forEach(function (btn) {
        btn.addEventListener('click', function (e) {
          e.preventDefault();
          var url = window.location.href;
          if (navigator.clipboard) {
            navigator.clipboard.writeText(url).then(function () {
              var icon = btn.querySelector('svg');
              var original = icon.innerHTML;
              icon.innerHTML = '<polyline points="20 6 9 17 4 12" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>';
              setTimeout(function () { icon.innerHTML = original; }, 2000);
            });
          } else {
            var input = document.createElement('input');
            input.value = url;
            document.body.appendChild(input);
            input.select();
            document.execCommand('copy');
            document.body.removeChild(input);
          }
        });
      });
    })();
  </script>
{% endblock %}
