{% extends "layout.jinja" %}

{% set blog = post if post is defined else blog %}
{% set cover_image = blog.cover.image.large if blog.cover and blog.cover.image else none %}
{% set blog_category = blog.category if blog.category else none %}
{% set all_tags = blog.tags | default([]) %}
{% set featured_products = blog.related_products | default([]) %}
{% set related_posts = blog.related_posts | default([]) %}
{% set share_url = store.permalink ~ 'blogs/' ~ blog.slug %}

{% block title %}{{ blog.title }} – {{ store.name }}{% endblock %}

{% block content %}
  {# Breadcrumb Section #}
  <section class="px-4 py-6 md:px-16">
    <div class="theme-container">
      {% set breadcrumb_items = [
        {'href': url_for('home'), 'label': _("Home")},
        {'href': '/blogs', 'label': _("Blog")}
      ] %}
      {% if blog_category and blog_category.name %}
        {% set breadcrumb_items = breadcrumb_items + [{'href': '/blogs?category=' ~ blog_category.slug, 'label': blog_category.name}] %}
      {% endif %}
      {% set breadcrumb_items = breadcrumb_items + [{'label': blog.title}] %}
      {% with items=breadcrumb_items %}
        {% include 'components/ui/breadcrumb.jinja' %}
      {% endwith %}
    </div>
  </section>

  {# Blog Post Content #}
  <section class="px-4 pb-8 md:px-16 md:pb-16">
    <div class="theme-container">
      <article class="mx-auto max-w-[900px]">
        {# Cover Image #}
        {% if cover_image %}
          <div class="mb-8 w-full overflow-hidden rounded aspect-[21/9]">
            <img
              src="{{ cover_image }}"
              alt="{{ blog.title }}"
              class="h-full w-full object-cover"
              fetchpriority="high"
            />
          </div>
        {% endif %}

        {# Title #}
        <h1 class="text-foreground text-2xl font-bold uppercase leading-tight md:text-[32px]">
          {{ blog.title }}
        </h1>

        {# Date + Share Icons row #}
        <div class="mt-3 mb-6 flex items-center justify-between">
          {% if blog.published_at %}
            <span class="text-foreground text-sm" dir="ltr" data-blog-date="{{ blog.published_at }}">
              {{ blog.published_at }}
            </span>
          {% else %}
            <span></span>
          {% endif %}
          {% with share_title=blog.title, share_url=share_url %}
            {% include 'components/blogs/blog-share.jinja' %}
          {% endwith %}
        </div>

        {# Rich Text Content #}
        <div class="prose prose-theme max-w-none">
          {{ blog.content | safe }}
        </div>

        {# Tags + Share Icons #}
        <div class="mt-6 flex items-center justify-between gap-4">
          <div class="flex flex-wrap items-center gap-3">
            {% if blog_category %}
              <span class="bg-secondary text-foreground inline-flex items-center rounded px-3 py-1 text-xs font-medium">
                {{ blog_category.name }}
              </span>
            {% endif %}
            {% for tag in all_tags %}
              <span class="bg-secondary text-foreground inline-flex items-center rounded px-3 py-1 text-xs">
                {{ tag.name }}
              </span>
            {% endfor %}
          </div>
          {% with share_title=blog.title, share_url=share_url %}
            {% include 'components/blogs/blog-share.jinja' %}
          {% endwith %}
        </div>
      </article>
    </div>
  </section>

  {# Featured Products #}
  {% if featured_products | length > 0 %}
    <section class="px-4 py-6 md:px-16 md:py-8">
      <div class="theme-container">
        {%
          with
          products=featured_products,
          title=_("Featured Products"),
          more_url=url_for('list_products'),
          more_text=_("View all"),
          carousel_id='blog-featured-products',
          is_priority_section=false
        %}
          {% include 'components/products/products-carousel.jinja' %}
        {% endwith %}
      </div>
    </section>
  {% endif %}

  {# You May Also Like — Related Posts #}
  {% if related_posts | length > 0 %}
    <section class="px-4 py-6 md:px-16 md:py-8">
      <div class="theme-container">
        {%
          with
          posts=related_posts,
          title=_("You may also like"),
          more_url='/blogs',
          more_text=_("View all"),
          carousel_id='blog-related-posts'
        %}
          {% include 'components/blogs/blogs-carousel.jinja' %}
        {% endwith %}
      </div>
    </section>
  {% endif %}

  {% include 'components/blogs/blog-scripts.jinja' %}
{% endblock %}
