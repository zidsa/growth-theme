{% extends "layout.jinja" %}

{% block title %}{{ post.title }} – {{ store.name }}{% endblock %}

{% block content %}
  <style>
    /* Reuse the same blog-card styling from blogs.jinja on related posts */
    .blog-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2.5rem 1.5rem;
    }
    @media (min-width: 768px) {
      .blog-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (min-width: 1024px) {
      .blog-grid { grid-template-columns: repeat(3, 1fr); }
    }
    .blog-card {
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    .blog-card-image {
      position: relative;
      display: block;
      width: 100%;
      aspect-ratio: 4 / 3;
      overflow: hidden;
      border-radius: var(--radius, 0.25rem) var(--radius, 0.25rem) 0 0;
    }
    .blog-card-image img,
    .blog-card-image .blog-card-placeholder {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .blog-card-placeholder {
      display: flex;
      align-items: center;
      justify-content: center;
      background: #F6F5F4;
    }
    .blog-card-content {
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding: 20px 24px 24px;
      background: #F6F5F4;
      flex: 1;
      border-radius: 0 0 var(--radius, 0.25rem) var(--radius, 0.25rem);
    }
    .blog-card-title {
      font-size: 24px;
      font-weight: 700;
      line-height: 1.3;
      text-transform: uppercase;
      color: var(--foreground, #0B0A09);
      margin: 0;
    }
    .blog-card-title a {
      color: inherit;
      text-decoration: none;
    }
    .blog-card-description {
      font-size: 14px;
      font-weight: 400;
      line-height: 1.5;
      color: var(--foreground, #0B0A09);
      margin: 0;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .blog-card-tags {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 8px;
    }
    .blog-tag {
      display: inline-flex;
      align-items: center;
      border: 1px solid var(--foreground, #0B0A09);
      border-radius: 9999px;
      padding: 4px 12px;
      font-size: 12px;
      line-height: 1.5;
      color: var(--foreground, #0B0A09);
    }
    .blog-tag--category { font-weight: 500; }
    .blog-tag--more {
      border-color: var(--border, #B5B5B5);
      color: var(--muted, #545352);
    }
    .blog-card-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: auto;
      padding-top: 8px;
    }
    .blog-card-date {
      font-size: 14px;
      color: var(--foreground, #0B0A09);
    }
    .blog-card-readmore {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 14px;
      font-weight: 500;
      color: var(--foreground, #0B0A09);
      text-decoration: none;
      margin-inline-start: auto;
    }

    /* Blog detail cover */
    .blog-detail-cover {
      width: 100%;
      aspect-ratio: 16 / 9;
      overflow: hidden;
      border-radius: var(--radius, 0.25rem);
      background: #F6F5F4;
    }
    .blog-detail-cover img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  </style>

  {# Breadcrumb Section #}
  <section class="px-4 py-6 md:px-16">
    <div class="theme-container">
      {% set breadcrumb_items = [
        {'href': url_for('home'), 'label': _("Home")},
        {'href': '/blogs', 'label': _("Blog")}
      ] %}
      {% if post.category and post.category.name %}
        {% set breadcrumb_items = breadcrumb_items + [{'href': '/blogs?category=' ~ post.category.slug, 'label': post.category.name}] %}
      {% endif %}
      {% set breadcrumb_items = breadcrumb_items + [{'label': post.title}] %}
      {% with items=breadcrumb_items %}
        {% include 'components/ui/breadcrumb.jinja' %}
      {% endwith %}
    </div>
  </section>

  {# Article #}
  <section class="px-4 pb-10 md:px-16">
    <div class="theme-container">
      <article class="mx-auto flex max-w-[900px] flex-col gap-6">
        {# Category + meta row #}
        <div class="flex flex-wrap items-center gap-3 text-sm">
          {% if post.category and post.category.name %}
            <a
              href="/blogs?category={{ post.category.slug }}"
              class="blog-tag blog-tag--category"
              data-category-id="{{ post.category.id }}"
              title="{{ post.category.description or post.category.name }}"
            >
              {% if post.category.icon %}
                <img
                  src="{{ post.category.icon }}"
                  alt=""
                  aria-hidden="true"
                  class="size-4 object-contain ltr:mr-1 rtl:ml-1"
                />
              {% endif %}
              {{ post.category.name }}
            </a>
          {% endif %}
          {% if post.published_at %}
            <span class="text-muted" aria-hidden="true">•</span>
            <time
              class="text-muted"
              datetime="{{ post.published_at }}"
            >
              {{ post.published_at[:10] }}
            </time>
          {% endif %}
        </div>

        {# Title #}
        <h1 class="text-foreground text-2xl md:text-4xl font-bold tracking-tight uppercase">
          {{ post.title }}
        </h1>

        {# Snippet as lead #}
        {% if post.snippet %}
          <p class="text-muted text-lg leading-relaxed">
            {{ post.snippet | striptags }}
          </p>
        {% endif %}

        {# Cover image #}
        {% set cover_src =
          (post.cover.image.full_size if post.cover and post.cover.image and post.cover.image.full_size else None)
          or (post.cover.image.large if post.cover and post.cover.image and post.cover.image.large else None)
          or (post.cover.image.medium if post.cover and post.cover.image and post.cover.image.medium else None)
          or (post.cover.file if post.cover and post.cover.file else None)
        %}
        {% if cover_src %}
          <figure class="blog-detail-cover">
            <img
              src="{{ cover_src }}"
              alt="{{ post.cover.alt_text or post.title }}"
              fetchpriority="high"
            />
          </figure>
        {% endif %}

        {# Rich text content #}
        {% if post.content %}
          <div class="prose prose-theme max-w-none">{{ post.content | safe }}</div>
        {% endif %}

        {# Tags #}
        {% if post.tags and post.tags | length > 0 %}
          <div class="flex flex-wrap items-center gap-2 border-t border-border pt-6">
            <span class="text-muted text-sm ltr:mr-2 rtl:ml-2">{{ _("Tags") }}:</span>
            {% for tag in post.tags %}
              {% if tag.name %}
                <a
                  {% if tag.slug %}href="/blogs?tags={{ tag.slug }}"{% endif %}
                  class="blog-tag"
                  data-tag-id="{{ tag.id }}"
                >
                  #{{ tag.name }}
                </a>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}
      </article>
    </div>
  </section>

  {# Related Products (reuse product-card) #}
  {% if post.related_products and post.related_products | length > 0 %}
    <section class="px-4 pb-10 md:px-16">
      <div class="theme-container">
        <div class="flex flex-col gap-6">
          <h2 class="text-foreground text-xl md:text-2xl font-semibold tracking-tight">
            {{ _("Featured products") }}
          </h2>
          <div
            data-grid-root="true"
            data-grid="four"
            class="group/grid grid gap-x-4 gap-y-10 data-[grid=four]:grid-cols-1 data-[grid=four]:md:grid-cols-2 data-[grid=four]:lg:grid-cols-4"
          >
            {% for product in post.related_products %}
              {% with index=loop.index0, is_priority=false %}
                {% include 'components/products/product-card.jinja' %}
              {% endwith %}
            {% endfor %}
          </div>
        </div>
      </div>
    </section>
  {% endif %}

  {# Related Posts (reuse blog-card) #}
  {% if post.related_posts and post.related_posts | length > 0 %}
    <section class="px-4 pb-16 md:px-16">
      <div class="theme-container">
        <div class="flex flex-col gap-6">
          <h2 class="text-foreground text-xl md:text-2xl font-semibold tracking-tight">
            {{ _("Related posts") }}
          </h2>
          <div class="blog-grid">
            {% for blog in post.related_posts %}
              {% include 'components/blogs/blog-card.jinja' %}
            {% endfor %}
          </div>
        </div>
      </div>
    </section>
  {% endif %}
{% endblock %}
