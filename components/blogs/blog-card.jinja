{#
  Blog Card Component

  Props:
  - blog: the blog post object (id, title, slug, snippet, cover, category, tags, published_at)
#}

{% set cover_src =
  (blog.cover.image.medium if blog.cover and blog.cover.image and blog.cover.image.medium else None)
  or (blog.cover.image.large if blog.cover and blog.cover.image and blog.cover.image.large else None)
  or (blog.cover.image.full_size if blog.cover and blog.cover.image and blog.cover.image.full_size else None)
  or (blog.cover.file if blog.cover and blog.cover.file else None)
%}
{% set post_url = '/blogs/' ~ blog.slug %}

<article
  class="blog-card"
  data-blog-card="{{ blog.id }}"
>
  <a
    href="{{ post_url }}"
    class="blog-card-image"
    aria-label="{{ blog.title }}"
  >
    {% if cover_src %}
      <img
        src="{{ cover_src }}"
        alt="{{ blog.cover.alt_text or blog.title or '' }}"
        {% if loop is defined and loop.index0 > 3 %}loading="lazy"{% endif %}
      />
    {% else %}
      <span class="blog-card-placeholder" aria-hidden="true">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="48"
          height="48"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-muted"
        >
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
          <circle cx="9" cy="9" r="2" />
          <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
        </svg>
      </span>
    {% endif %}
  </a>

  <div class="blog-card-content">
    {# Tags row: category + up to 2 tags + "more" pill #}
    {% if blog.category or blog.tags %}
      <div class="blog-card-tags">
        {% if blog.category and blog.category.name %}
          <a
            href="/blogs?category={{ blog.category.slug }}"
            class="blog-tag blog-tag--category"
          >
            {{ blog.category.name }}
          </a>
        {% endif %}
        {% if blog.tags %}
          {% set visible_tags = blog.tags[:2] %}
          {% for tag in visible_tags %}
            {% if tag.name %}
              <span class="blog-tag">{{ tag.name }}</span>
            {% endif %}
          {% endfor %}
          {% if blog.tags | length > 2 %}
            <span class="blog-tag blog-tag--more">
              +{{ blog.tags | length - 2 }}
            </span>
          {% endif %}
        {% endif %}
      </div>
    {% endif %}

    <h2 class="blog-card-title">
      <a href="{{ post_url }}">{{ blog.title }}</a>
    </h2>

    {% if blog.snippet %}
      <p class="blog-card-description">{{ blog.snippet | striptags }}</p>
    {% endif %}

    <div class="blog-card-footer">
      {% if blog.published_at %}
        <time
          class="blog-card-date"
          datetime="{{ blog.published_at }}"
        >
          {{ blog.published_at[:10] }}
        </time>
      {% endif %}
      <a
        href="{{ post_url }}"
        class="blog-card-readmore"
        aria-label="{{ _('Read more') }}: {{ blog.title }}"
      >
        {{ _("Read more") }}
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="rtl:rotate-180"
        >
          <path d="M5 12h14" />
          <path d="m12 5 7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</article>
